---
import { getCollection } from 'astro:content'

export const frontmatter = { menu: false }

export async function getStaticPaths() {
  const lieder = await getCollection('liederbuch')
  return lieder.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}


import Layout from "../../../layouts/BaseLayout.astro"
const { entry } = Astro.props
const { Content } = await entry.render()
const title = entry.data.title ?? "Lied"
---

<Layout frontmatter={{ title }}>
  <h1>{title}</h1>
  <Content />
</Layout>


<style>
:global(.prose :where(blockquote p:first-of-type):not(:where([class~="not-prose"], [class~="not-prose"] *))::before),
:global(.prose :where(blockquote p:first-of-type):not(:where([class~="not-prose"], [class~="not-prose"] *))::after) {
  content: none;
}

</style>